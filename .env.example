# OpenCode Go Multi-Auth - Environment Variables
#
# Set one variable per profile, matching the apiKeyEnv field
# in your opencode.json profile definitions.

# Personal account
OPENCODE_GO_PERSONAL_KEY=oc_go_your_personal_key_here

# Work account
OPENCODE_GO_WORK_KEY=oc_go_your_work_key_here

# Alt account
OPENCODE_GO_ALT_KEY=oc_go_your_alt_key_here
